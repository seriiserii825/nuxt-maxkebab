{
  "name": "nuxt-maxkebab",
  "type": "module",
  "private": true,
  "scripts": {
    "prebuild": "npx stylelint '**/*.scss' --fix && vue-tsc --noEmit --skipLibCheck && eslint .",
    "build": "nuxt build",
    "predev": "npx stylelint '**/*.scss' --fix && vue-tsc --noEmit --skipLibCheck && eslint .",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "format:scss": "npx stylelint '**/*.scss' --fix",
    "type:check": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@nuxtjs/i18n": "10.2.4",
    "@pinia-plugin-persistedstate/nuxt": "^1.2.1",
    "@pinia/nuxt": "^0.11.3",
    "nuxt": "^4.4.2",
    "swiper": "^12.1.3",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4",
    "stylelint": "^16.21.1",
    "stylelint-config-standard-scss": "^15.0.1",
    "stylelint-order": "^7.0.0",
    "stylelint-scss": "^6.12.1"
  },
  "engines": {
    "node": "22.*"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "sass": "^1.99.0",
    "eslint": "^9.39.2",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "eslint-plugin-vue": "^10.6.2",
    "typescript-eslint": "^8.50.1",
    "vue-tsc": "^3.0.7"
  }
}
